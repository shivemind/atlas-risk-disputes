# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atlas_risk?schema=public"

# ── Server ─────────────────────────────────────────────────────────────
PORT=3003

# ── Redis (Upstash) — optional for local dev ──────────────────────────
# REDIS_REST_URL=
# REDIS_REST_TOKEN=

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Idempotency ──────────────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=86400

# ── Webhooks ─────────────────────────────────────────────────────────
WEBHOOK_RETRY_BASE_SECONDS=30
WEBHOOK_RETRY_MAX_SECONDS=3600

# ── Cron ─────────────────────────────────────────────────────────────
# CRON_SECRET=
